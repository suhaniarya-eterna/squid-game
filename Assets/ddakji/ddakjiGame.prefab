  m_EditorClassIdentifier: Assembly-CSharp::SquidIntroTaunter
  tauntText: {fileID: 2699332248552737327}
  textFadeDuration: 0.4
  taunts:
  - First game. Ddakji.
  - 'Get 1000$ to move to next level '
  - Flip the tile. If it turns, you win.
  - "If it doesn\u2019t\u2026 you\u2019ll understand."
  - "It\u2019s not the game. It\u2019s you."
  timeBetweenTaunts: 3.5

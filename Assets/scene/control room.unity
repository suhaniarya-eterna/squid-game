  m_Script: {fileID: 11500000, guid: f0f469757d2c5de488698cc2b91883e3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SquidIntroTaunter
  tauntText: {fileID: 7674775259823754080}
  textFadeDuration: 0.4
  taunts:
  - "Welcome, player. The rules are simple\u2026 but judging by your last attempts,
    simple isn\u2019t your strength."
  - "Your task: survive without getting rage baited. Let\u2019s see how long your
    patience lasts\u2026 I\u2019m betting seconds."
  - "Every mistake will feel personal. That\u2019s intentional. The game isn\u2019t
    broken\u2026 you are."
  - All the best you will need it!!
  timeBetweenTaunts: 5.5
